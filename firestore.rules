rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ===== Users =====
    match /users/{uid} {
      allow read: if true; // לדירוג ציבורי
      // המשתמש יכול ליצור את הרשומה שלו, אך לא לעדכן totalPoints/predictionsCount —
      // אלה מעודכנים על-ידי Functions בלבד.
      allow create: if isSelf(uid)
                    && request.resource.data.totalPoints == 0
                    && request.resource.data.predictionsCount == 0;
      // Self can edit own profile (e.g. department) but not points/count.
      // Admins can also edit any user's profile (e.g. assign department) but not points/count.
      allow update: if (isSelf(uid) || isAdmin())
                    && request.resource.data.totalPoints == resource.data.totalPoints
                    && request.resource.data.predictionsCount == resource.data.predictionsCount;
      allow delete: if isAdmin();
    }

    // App-config / admin helper (defined before use by /matches).
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/appConfig/main) &&
        request.auth.token.email in get(/databases/$(database)/documents/appConfig/main).data.adminEmails;
    }

    // ===== Matches =====
    // Public read. Writes: the GitHub Actions sync (service account, bypasses
    // rules) and admins via the Admin "Matches" tab (manual override).
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== Stats (golden boot, hall of fame) — written by the sync worker only =====
    match /stats/{docId} {
      allow read: if true;
      allow write: if isAdmin(); // sync worker uses Admin SDK; admins can edit manually (e.g. Golden Boot)
    }

    // ===== Public matches snapshot (one doc, written by the sync) =====
    match /snapshot/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ===== Match previews (ESPN form / H2H / news) — written by matchPreview fn =====
    match /matchPreviews/{matchId} {
      allow read: if true;   // public, read-only context for the match room
      allow write: if false; // admin SDK only (bypasses rules)
    }

    // ===== Playground (live-pipeline test) — written by the playground scripts only =====
    match /playgroundSnapshot/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /playgroundMatches/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /playgroundMeta/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ===== App state (king, kingMessage, pundit) =====
    // Sync worker writes via admin SDK (bypasses rules). Admins can edit/override
    // any of these from the automation panel. The king may post their own message.
    match /appState/{docId} {
      allow read: if true;
      allow write: if isAdmin()
                   || (docId == 'kingMessage' && isSignedIn() && request.resource.data.byUid == request.auth.uid);
    }

    // ===== Polls =====
    match /pollVotes/{voteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && voteId == request.auth.uid + '_' + request.resource.data.pollId
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /pollTally/{pollId} {
      allow read: if true;
      // anyone signed-in can bump (increment via setDoc merge)
      allow write: if isSignedIn();
    }

    // ===== Survey responses (multi-question, single-choice; results public) =====
    match /surveyResponses/{respId} {
      allow read: if true; // results are always public
      allow create, update: if isSignedIn()
        && respId == request.auth.uid + '_' + request.resource.data.surveyId
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // ===== Bonus predictions (championship + top scorer) =====
    match /bonusPredictions/{uid} {
      allow read: if isSignedIn();

      function bonusLocked() {
        // Locked once the first game kicks off. The sync writes the earliest
        // kickoff to appState/timing.bonusLockAt; before that doc exists, open.
        return exists(/databases/$(database)/documents/appState/timing)
          && request.time >= get(/databases/$(database)/documents/appState/timing).data.bonusLockAt;
      }

      allow create, update: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && !bonusLocked()
        // championPoints / topScorerPoints can only be set by Functions
        && request.resource.data.championPoints == null
        && request.resource.data.topScorerPoints == null;

      allow delete: if isAdmin();
    }

    // ===== Predictions =====
    match /predictions/{predId} {
      allow read: if isSignedIn();

      // יצירה/עדכון רק עבור הניחושים שלך, ורק אם המשחק עוד לא התחיל
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && predId == request.auth.uid + '_' + request.resource.data.matchId
                    && exists(/databases/$(database)/documents/matches/$(request.resource.data.matchId))
                    && get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.status == 'SCHEDULED'
                    && request.time < get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.kickoff
                    && request.resource.data.homeScore is int
                    && request.resource.data.awayScore is int
                    && request.resource.data.homeScore >= 0 && request.resource.data.homeScore <= 30
                    && request.resource.data.awayScore >= 0 && request.resource.data.awayScore <= 30
                    && request.resource.data.points == null;

      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid
                    && get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.status == 'SCHEDULED'
                    && request.time < get(/databases/$(database)/documents/matches/$(resource.data.matchId)).data.kickoff
                    && request.resource.data.points == resource.data.points
                    && request.resource.data.homeScore is int
                    && request.resource.data.awayScore is int
                    && request.resource.data.homeScore >= 0 && request.resource.data.homeScore <= 30
                    && request.resource.data.awayScore >= 0 && request.resource.data.awayScore <= 30;

      allow delete: if isAdmin();
    }

    // ===== User activity log =====
    // Signed-in users append their own events; only admins can read.
    match /userActivity/{eventId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ===== Match rooms (live chat / reactions) =====
    match /matches/{matchId}/chat/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

  }
}
